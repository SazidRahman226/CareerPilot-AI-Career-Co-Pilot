# ===== CareerPilot Environment Variables =====
# Copy this file to .env and fill in the values

# --- LLM Configuration ---
GOOGLE_API_KEY=your_google_api_key_here
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Job Search API (optional - falls back to mock data if not set) ---
SERPAPI_API_KEY=your_serpapi_key_here

# --- Database ---
DATABASE_URL=postgresql://careerpilot:careerpilot_secret@db:5432/careerpilot

# --- Authentication ---
JWT_SECRET_KEY=change_me_to_a_random_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=168

# --- CORS ---
FRONTEND_URL=http://localhost:3000

# --- Default User ---
DEFAULT_USER_EMAIL="user@example.com"
DEFAULT_USER_PASSWORD="user"

# --- Paths (optional - defaults will be used if not set) ---
# BASE_DIR=/app
# DATA_DIR=/app/data
# CHROMA_PERSIST_DIR=/app/data/chroma_db
# UPLOAD_DIR=/app/data/uploads
